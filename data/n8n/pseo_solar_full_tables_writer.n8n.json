      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nconst supabaseUrl = String($env.SUPABASE_URL || $env.NEXT_PUBLIC_SUPABASE_URL || '').trim();\nconst supabaseServiceRoleKey = String($env.SUPABASE_SERVICE_ROLE_KEY || '').trim();\nconst esiosApiToken = String($env.ESIOS_API_TOKEN || '').replace(/^Token\\s+/i, '').trim();\n\nif (!supabaseUrl) {\n  throw new Error('Missing SUPABASE_URL (or NEXT_PUBLIC_SUPABASE_URL fallback)');\n}\n\nif (!/^https?:\\/\\//i.test(supabaseUrl)) {\n  throw new Error('Invalid SUPABASE_URL format. Expected https://<project>.supabase.co');\n}\n\nif (!supabaseServiceRoleKey || supabaseServiceRoleKey.length < 20 || !supabaseServiceRoleKey.startsWith('sb_secret_')) {\n  throw new Error('Invalid SUPABASE_SERVICE_ROLE_KEY. Set a valid sb_secret_* key and remove duplicates');\n}\n\nconst env = {\n  SUPABASE_URL: supabaseUrl,\n  SUPABASE_SERVICE_ROLE_KEY: supabaseServiceRoleKey,\n  ESIOS_API_TOKEN: esiosApiToken,\n  ESIOS_TEST_JSON_URL: $env.ESIOS_TEST_JSON_URL || '',\n  GEO_SOURCE_CSV_URL: $env.GEO_SOURCE_CSV_URL || '',\n  IBI_ICIO_JSON_URL: $env.IBI_ICIO_JSON_URL || '',\n  COMPATIBILIDAD_CSV_URL: $env.COMPATIBILIDAD_CSV_URL || '',\n  PVGIS_BASE_URL: $env.PVGIS_BASE_URL || 'https://re.jrc.ec.europa.eu/api/v5_2',\n  BATCH_SIZE: parseInt($env.BATCH_SIZE || '50', 10),\n  DRY_RUN: ($env.DRY_RUN || 'false') === 'true',\n  STRICT_PROD: ($env.STRICT_PROD || 'true') === 'true',\n  AI_TO_STAGING_ONLY: ($env.AI_TO_STAGING_ONLY || 'true') === 'true',\n  AI_BASE_URL: $env.AI_BASE_URL || 'https://api.openai.com/v1/chat/completions',\n  AI_API_KEY: $env.AI_API_KEY || '',\n  AI_MODEL: $env.AI_MODEL || 'gpt-4o-mini'\n};\n\nstaticData.strictAlerts = [];\nstaticData.deadLetters = [];\n\nconst runId = `run_${Date.now()}`;\nconsole.log(JSON.stringify({\n  stage: 'INIT',\n  runId,\n  env: {\n    ...env,\n    SUPABASE_SERVICE_ROLE_KEY: '***',\n    ESIOS_API_TOKEN: env.ESIOS_API_TOKEN ? '***' : '',\n    AI_API_KEY: env.AI_API_KEY ? '***' : ''\n  }\n}));\n\nreturn [{ json: { ...env, runId, startedAt: new Date().toISOString() } }];"
      },
