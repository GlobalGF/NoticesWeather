      "id": "01f8ed51-a40c-4114-b40c-4a2c6998bb8b",
      "name": "Get municipios_dataset_es",
      "type": "n8n-nodes-base.httpRequest",
      "alwaysOutputData": true,
      "position": [
        16,
        64
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "const requiredNodes = [\n  'Get municipios_dataset_es',\n  'Get radiacion',\n  'Get IBI',\n  'Get subvenciones',\n  'Get tarifas',\n  'Get equipos',\n  'Get estimaciones',\n  'Get precios instalacion',\n  'Get compatibilidad',\n  'Get pseo slug index',\n  'Get pseo url index',\n];\n\nconst getItems = (nodeName) => {\n  try {\n    return $(nodeName).all() || [];\n  } catch (e) {\n    return [];\n  }\n};\n\nconst snapshots = {};\nfor (const nodeName of requiredNodes) {\n  snapshots[nodeName] = getItems(nodeName);\n}\n\nconst missingNodes = requiredNodes.filter((nodeName) => snapshots[nodeName].length === 0);\n\nconst base = $('Set Base Params').first()?.json || {};\nconst merged = { ...base };\n\nfor (const nodeName of requiredNodes) {\n  const first = snapshots[nodeName][0]?.json || {};\n  Object.assign(merged, first);\n}\n\n// Debug rapido para saber que ramas faltaron en esta ejecucion\nmerged.build_missing_nodes = missingNodes;\nmerged.build_ready_count = requiredNodes.length - missingNodes.length;\n\n// Mantener listas como arrays cuando el nodo devuelva multiples filas\nmerged.pseo_url_index_rows = snapshots['Get pseo url index'].map((i) => i.json);\nmerged.equipos_rows = snapshots['Get equipos'].map((i) => i.json);\n\nconst slug = merged.slug || '';\nconst municipio = merged.municipio || '';\nconst provincia = merged.provincia || '';\nconst comunidad = merged.comunidad_autonoma || '';\nconst model = merged.AI_MODEL || 'gpt-4o-mini';\n\nconst prompt = [\n  'Genera contenido SEO en espanol para instalacion de energia solar residencial.',\n  `Municipio: ${municipio}, Provincia: ${provincia}, Comunidad Autonoma: ${comunidad}`,\n  `Slug: ${slug}`,\n  'Basandote en los datos disponibles, devuelve SOLO un JSON valido con estos campos:',\n  '{ seo_title, seo_description, intro, beneficios, faqs }',\n].join('\\n');\n\nreturn [{\n  json: {\n    ...merged,\n    AI_BASE_URL: merged.AI_BASE_URL || 'https://api.openai.com/v1/chat/completions',\n    AI_MODEL: model,\n    openai_body: {\n      model,\n      messages: [\n        { role: 'system', content: 'Eres un redactor SEO experto en energia solar para Espana. Responde SIEMPRE con JSON valido.' },\n        { role: 'user', content: prompt },\n      ],\n      temperature: 0.3,\n    },\n  },\n}];"
      },
