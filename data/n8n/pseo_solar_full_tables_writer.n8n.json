      "id": "1c3b593a-6e3e-4853-a44d-3410fac034d8",
      "name": "AI content request",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        480,
        784
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $json;\n\nconst safeFirstJson = (nodeName) => {\n  try {\n    return $(nodeName).first()?.json || {};\n  } catch (e) {\n    return {};\n  }\n};\n\nconst upstream = safeFirstJson('Build prompt payload');\n\nconst init = safeFirstJson('INIT - Env & Config');\n\nconst envVars = {\n  SUPABASE_URL: $env.SUPABASE_URL || $env.NEXT_PUBLIC_SUPABASE_URL || '',\n  SUPABASE_SERVICE_ROLE_KEY: $env.SUPABASE_SERVICE_ROLE_KEY || '',\n  AI_BASE_URL: $env.AI_BASE_URL || 'https://api.openai.com/v1/chat/completions',\n  AI_MODEL: $env.AI_MODEL || 'gpt-4o-mini',\n};\n\nconst src = { ...envVars, ...init, ...upstream };\n\nlet parsed;\ntry {\n  const content = aiResponse?.choices?.[0]?.message?.content;\n  if (!content || typeof content !== 'string') {\n    throw new Error('AI response sin contenido en choices[0].message.content');\n  }\n\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  const jsonText = match ? match[0] : content;\n  parsed = JSON.parse(jsonText);\n} catch (err) {\n  return [{\n    json: {\n      ...src,\n      __error: true,\n      error_stage: 'validate_output',\n      error_message: String(err?.message || err),\n      ai_raw: aiResponse,\n      logged_at: new Date().toISOString(),\n    },\n  }];\n}\n\nconst beneficios = Array.isArray(parsed.beneficios) ? parsed.beneficios : [];\nconst faqs = Array.isArray(parsed.faqs) ? parsed.faqs : [];\n\nif (!src.slug || !src.municipio || !src.provincia || !src.comunidad_autonoma) {\n  return [{\n    json: {\n      ...src,\n      __error: true,\n      error_stage: 'validate_output',\n      error_message: 'Faltan campos obligatorios para upsert: slug/municipio/provincia/comunidad_autonoma',\n      ai_raw: aiResponse,\n      logged_at: new Date().toISOString(),\n    },\n  }];\n}\n\nconst narrativa = ['ahorro','sostenibilidad','independencia_energetica','revalorizacion'].includes(src.angulo_sugerido)\n  ? src.angulo_sugerido\n  : null;\n\nconst h2 = faqs\n  .map((f) => (typeof f === 'string' ? f : f?.pregunta || f?.question || ''))\n  .filter(Boolean)\n  .slice(0, 3);\n\nreturn [{\n  json: {\n    ...src,\n    ai_raw: aiResponse,\n    __error: false,\n    seo_title: parsed.seo_title || '',\n    seo_description: parsed.seo_description || '',\n    intro: parsed.intro || '',\n    beneficios,\n    faqs,\n    upsert_payload: {\n      slug: src.slug,\n      municipio: src.municipio,\n      provincia: src.provincia,\n      comunidad_autonoma: src.comunidad_autonoma,\n      intro_unica: parsed.intro || null,\n      analisis_fiscal_personalizado: beneficios.length ? beneficios.join('\\n') : null,\n      h2_variante: h2.length ? h2 : null,\n      conclusion_local: parsed.seo_description || null,\n      narrativa_angulo: narrativa,\n      irradiacion_solar: src.irradiacion_kwh_m2 ?? src.irradiacion_solar ?? null,\n      horas_sol: src.horas_sol_anuales ?? src.horas_sol ?? null,\n      ahorro_estimado: src.ahorro_estimado ?? null,\n      bonificacion_ibi: src.porcentaje_bonificacion ?? src.bonificacion_ibi ?? null,\n      subvencion_autoconsumo: src.subvencion_porcentaje ?? src.subvencion_autoconsumo ?? null,\n      precio_instalacion_medio_eur: src.precio_medio_eur ?? src.precio_instalacion_medio_eur ?? null,\n      precio_medio_luz: src.precio_kwh_dia ?? src.precio_medio_luz ?? null,\n      habitantes: src.habitantes ?? null,\n      modelo_ia: src.AI_MODEL || envVars.AI_MODEL,\n      last_generated_at: new Date().toISOString(),\n      needs_regen: false,\n      updated_at: new Date().toISOString(),\n    },\n  },\n}];"
      },
