        "jsCode": "const items = $input.all();\nconst init = $('INIT - Env & Config').item.json;\n\nreturn items.map((item) => ({\n  json: {\n    ...init,\n    ...item.json,\n    slug: item.json.slug || '',\n    municipio: item.json.municipio || '',\n    provincia: item.json.provincia || '',\n    comunidad_autonoma: item.json.comunidad_autonoma || '',\n    habitantes: Number(item.json.habitantes || 0),\n  },\n}));"
