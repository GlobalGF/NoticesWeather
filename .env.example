AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# Sources for n8n pipelines
GEO_SOURCE_CSV_URL=https://raw.githubusercontent.com/GlobalGF/NoticesWeather/refs/heads/main/docs/municipios.csv
IBI_ICIO_JSON_URL=https://raw.githubusercontent.com/GlobalGF/NoticesWeather/refs/heads/main/docs/bonificaciones.json
COMPATIBILIDAD_CSV_URL=https://raw.githubusercontent.com/GlobalGF/NoticesWeather/main/scripts/python/compatibility_input.example.csv

# ESIOS mode:
# 1) TEST without token -> set ESIOS_TEST_JSON_URL and leave ESIOS_API_TOKEN empty
# 2) REAL API -> set ESIOS_API_TOKEN and leave ESIOS_TEST_JSON_URL empty
ESIOS_TEST_JSON_URL=https://raw.githubusercontent.com/GlobalGF/NoticesWeather/refs/heads/main/docs/bonificaciones_ibi_icio.example.json

# Optional legal sources for BONIF AI extraction
BONIF_SOURCE_URLS=

# Runtime controls
DRY_RUN=false
STRICT_PROD=true
AI_TO_STAGING_ONLY=true
BATCH_SIZE=50

# Optional CSV source for automated go/no-go
SEO_METRICS_CSV_PATH=docs/seo-metrics-weekly.example.csv

# SEO launch observability inputs (weekly)
# Ratios as decimal: 0.72 = 72%
SEO_OBS_INDEXED_RATE=0.65
SEO_OBS_SOFT404_RATE=0.03
SEO_OBS_ORGANIC_CTR=0.025
SEO_OBS_ENGAGED_SECONDS=45

# Optional alert thresholds (if omitted, script uses phase-aware defaults)
SEO_ALERT_MIN_INDEXED_RATE=0.60
SEO_ALERT_SOFT404_RATE=0.04
SEO_ALERT_MIN_ORGANIC_CTR=0.022
SEO_ALERT_MIN_ENGAGED_SECONDS=40
