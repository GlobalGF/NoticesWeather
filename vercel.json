{
  "crons": [
    {
      "path": "/api/cron/publish-drip",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-pvpc",
      "schedule": "15 19 * * *"
    }
  ],
  "headers": [
    {
      "source": "/icon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    },
    {
      "source": "/apple-icon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=604800" }
      ]
    }
  ]
}
